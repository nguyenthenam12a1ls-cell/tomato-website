generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  avatar    String   @default("")
  phone     String   @default("")
  street    String   @default("")
  ward      String   @default("")
  province  String   @default("")
  country   String   @default("")
  dob       String   @default("")  
  gender    String   @default("")   
  bio       String   @default("")   
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart?
  orders    Order[]
}

model Food {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  price       Float
  image       String
  category    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([category])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  foodId    Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([cartId, foodId])
  @@index([cartId])
}

model Order {
  id             Int         @id @default(autoincrement())
  userId         Int
  amount         Float
  status         String      @default("Food Processing")
  payment        Boolean     @default(false)
  paymentMethod  String      @default("cod")
  originalAmount Float?
  currency       String      @default("usd")

  firstName      String
  lastName       String
  email          String
  street         String
  city           String
  state          String
  zipcode        String
  country        String
  phone          String

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@index([userId, status, createdAt])
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  foodId     Int?
  foodName   String
  foodPrice  Float
  quantity   Int
  createdAt  DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  food       Food?    @relation(fields: [foodId], references: [id], onDelete: SetNull)
}

model Voucher {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  discount     Float
  discountType String   @default("percent")  // "percent" (phần trăm) hoặc "fixed" (trừ thẳng tiền)
  minOrder     Float    @default(0)          // Đơn tối thiểu để áp dụng
  maxUses      Int      @default(100)        // Số lượt dùng tối đa
  usedCount    Int      @default(0)          // Đã dùng bao nhiêu lượt
  expiresAt    DateTime                      // Ngày hết hạn
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
